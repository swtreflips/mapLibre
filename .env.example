# Copy to .env and fill in. .env is gitignored.

# Client-side (browser). Vite only exposes VITE_-prefixed vars.
# Use the ANON / public key — safe to bundle (relies on RLS). NEVER the service-role key.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only (e.g. the Python snapshot push). NOT VITE_-prefixed, never sent to the browser.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-service-role-key
